# Local .terraform directory (contains provider binaries and modules)
.terraform/

# .tfstate files (contain infrastructure state and potentially secrets)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variables files (often contain sensitive secrets)
*.tfvars
*.tfvars.json

# Local-only override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc
